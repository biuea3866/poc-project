{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EmployeeSalaryChanged",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "aggregateType",
    "aggregateId",
    "companyId",
    "action",
    "state"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "EmployeeSalaryChanged"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "aggregateType": {
      "type": "string",
      "const": "Employment"
    },
    "aggregateId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "details"],
      "properties": {
        "type": {
          "type": "string",
          "const": "SALARY_CHANGE"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["oldBaseSalary", "newBaseSalary", "currency"],
          "properties": {
            "oldBaseSalary": {
              "type": "number"
            },
            "newBaseSalary": {
              "type": "number"
            },
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "snapshot"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PRE_HIRED", "ACTIVE", "ON_LEAVE", "RESIGNED"]
        },
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["departmentId", "country", "currency", "timezone"],
          "properties": {
            "departmentId": {
              "type": ["integer", "null"]
            },
            "managerEmploymentId": {
              "type": ["integer", "null"]
            },
            "country": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3
            },
            "timezone": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
