{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DepartmentHeadChanged",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "aggregateType",
    "aggregateId",
    "companyId",
    "action",
    "state"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "DepartmentHeadChanged"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "aggregateType": {
      "type": "string",
      "const": "Department"
    },
    "aggregateId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": [
        "integer",
        "null"
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "details"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "HEAD_CHANGE"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "oldHeadEmploymentId",
            "newHeadEmploymentId"
          ],
          "properties": {
            "oldHeadEmploymentId": {
              "type": [
                "integer",
                "null"
              ]
            },
            "newHeadEmploymentId": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "snapshot"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ACTIVE",
            "ARCHIVED"
          ],
          "description": "Department lifecycle 상태 (active or archived)"
        },
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "headEmploymentId"
          ],
          "properties": {
            "headEmploymentId": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        }
      }
    }
  }
}
