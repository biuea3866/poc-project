{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Employee Resigned Event",
  "type": "object",
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["employee.resigned"]
    },
    "eventVersion": {
      "type": "integer",
      "minimum": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "employmentId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "reason": {
      "type": ["string", "null"]
    },
    "effectiveDate": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "eventType",
    "eventVersion",
    "occurredAt",
    "employmentId",
    "companyId",
    "actorEmploymentId",
    "reason",
    "effectiveDate"
  ],
  "additionalProperties": false
}
