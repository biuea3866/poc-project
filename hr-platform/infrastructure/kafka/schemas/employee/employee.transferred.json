{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Employee Transferred Event",
  "type": "object",
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["employee.transferred"]
    },
    "eventVersion": {
      "type": "integer",
      "minimum": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "employmentId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "oldDepartmentId": {
      "type": "integer"
    },
    "newDepartmentId": {
      "type": "integer"
    }
  },
  "required": [
    "eventType",
    "eventVersion",
    "occurredAt",
    "employmentId",
    "companyId",
    "actorEmploymentId",
    "oldDepartmentId",
    "newDepartmentId"
  ],
  "additionalProperties": false
}
