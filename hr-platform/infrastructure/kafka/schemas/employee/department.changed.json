{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DepartmentChanged",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "aggregateType",
    "aggregateId",
    "companyId",
    "action",
    "state"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "DepartmentChanged"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "aggregateType": {
      "type": "string",
      "const": "Department"
    },
    "aggregateId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "details"],
      "properties": {
        "type": {
          "type": "string",
          "const": "DEPARTMENT_MOVE"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["oldParentId", "newParentId", "oldPath", "newPath"],
          "properties": {
            "oldParentId": {
              "type": ["integer", "null"]
            },
            "newParentId": {
              "type": ["integer", "null"]
            },
            "oldPath": {
              "type": "string"
            },
            "newPath": {
              "type": "string"
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot"],
      "properties": {
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["parentId", "path", "headEmploymentId"],
          "properties": {
            "parentId": {
              "type": ["integer", "null"]
            },
            "path": {
              "type": "string"
            },
            "headEmploymentId": {
              "type": ["integer", "null"]
            },
            "effectiveFrom": {
              "type": ["string", "null"],
              "format": "date-time"
            },
            "effectiveTo": {
              "type": ["string", "null"],
              "format": "date-time"
            }
          }
        }
      }
    }
  }
}
