{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AttendanceLateRecorded",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "aggregateType",
    "aggregateId",
    "companyId",
    "action",
    "state"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "AttendanceLateRecorded"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "aggregateType": {
      "type": "string",
      "const": "AttendanceRecord"
    },
    "aggregateId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "details"],
      "properties": {
        "type": {
          "type": "string",
          "const": "MARK_LATE"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["employmentId", "workDate", "checkInAt", "scheduledStart"],
          "properties": {
            "employmentId": {
              "type": "integer"
            },
            "workDate": {
              "type": "string",
              "format": "date"
            },
            "checkInAt": {
              "type": "string",
              "format": "date-time"
            },
            "scheduledStart": {
              "type": "string",
              "format": "date-time"
            },
            "delayMinutes": {
              "type": "integer"
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "snapshot"],
      "properties": {
        "status": {
          "type": "string",
          "const": "IN_PROGRESS"
        },
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["employmentId", "workDate"],
          "properties": {
            "employmentId": {
              "type": "integer"
            },
            "workDate": {
              "type": "string",
              "format": "date"
            }
          }
        }
      }
    }
  }
}
