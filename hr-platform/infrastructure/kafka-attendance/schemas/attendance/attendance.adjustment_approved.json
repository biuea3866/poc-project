{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AttendanceAdjustmentApproved",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "aggregateType",
    "aggregateId",
    "companyId",
    "action",
    "state"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "AttendanceAdjustmentApproved"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "aggregateType": {
      "type": "string",
      "const": "AttendanceAdjustmentRequest"
    },
    "aggregateId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "details"],
      "properties": {
        "type": {
          "type": "string",
          "const": "APPROVE_ADJUST"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requestId", "attendanceRecordId", "approvedBy"],
          "properties": {
            "requestId": {
              "type": "integer"
            },
            "attendanceRecordId": {
              "type": "integer"
            },
            "approvedBy": {
              "type": "integer"
            },
            "reviewComment": {
              "type": ["string", "null"]
            },
            "appliedField": {
              "type": ["string", "null"]
            },
            "appliedValue": {
              "type": ["string", "null"]
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "snapshot"],
      "properties": {
        "status": {
          "type": "string",
          "const": "COMPLETED"
        },
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requestId", "attendanceRecordId"],
          "properties": {
            "requestId": {
              "type": "integer"
            },
            "attendanceRecordId": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
