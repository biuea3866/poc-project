{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AttendanceAdjustmentRequested",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "aggregateType",
    "aggregateId",
    "companyId",
    "action",
    "state"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "AttendanceAdjustmentRequested"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "aggregateType": {
      "type": "string",
      "const": "AttendanceAdjustmentRequest"
    },
    "aggregateId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "details"],
      "properties": {
        "type": {
          "type": "string",
          "const": "REQUEST_ADJUST"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requestId", "attendanceRecordId", "requestedField", "requestedValue", "originalValue", "reason", "requestedBy"],
          "properties": {
            "requestId": {
              "type": "integer"
            },
            "attendanceRecordId": {
              "type": "integer"
            },
            "requestedField": {
              "type": "string",
              "enum": ["CHECK_IN_TIME", "CHECK_OUT_TIME", "WORK_DATE", "LATE_FLAG", "ABSENT_FLAG"]
            },
            "requestedValue": {
              "type": "string"
            },
            "originalValue": {
              "type": ["string", "null"]
            },
            "reason": {
              "type": "string"
            },
            "requestedBy": {
              "type": "integer"
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "snapshot"],
      "properties": {
        "status": {
          "type": "string",
          "const": "PENDING"
        },
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requestId", "attendanceRecordId"],
          "properties": {
            "requestId": {
              "type": "integer"
            },
            "attendanceRecordId": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
