{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AttendanceAdjusted",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "aggregateType",
    "aggregateId",
    "companyId",
    "action",
    "state"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "AttendanceAdjusted"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "aggregateType": {
      "type": "string",
      "const": "AttendanceRecord"
    },
    "aggregateId": {
      "type": "integer"
    },
    "companyId": {
      "type": "integer"
    },
    "actorEmploymentId": {
      "type": ["integer", "null"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "details"],
      "properties": {
        "type": {
          "type": "string",
          "const": "ADJUST"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attendanceRecordId", "employmentId", "workDate", "adjustedField", "oldValue", "newValue", "adjustedBy"],
          "properties": {
            "attendanceRecordId": {
              "type": "integer"
            },
            "employmentId": {
              "type": "integer"
            },
            "workDate": {
              "type": "string",
              "format": "date"
            },
            "adjustedField": {
              "type": "string",
              "enum": ["CHECK_IN_TIME", "CHECK_OUT_TIME", "WORK_DATE", "LATE_FLAG", "ABSENT_FLAG"]
            },
            "oldValue": {
              "type": ["string", "null"]
            },
            "newValue": {
              "type": "string"
            },
            "adjustedBy": {
              "type": "integer"
            },
            "adjustReason": {
              "type": ["string", "null"]
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "snapshot"],
      "properties": {
        "status": {
          "type": "string",
          "const": "COMPLETED"
        },
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attendanceRecordId", "employmentId", "workDate"],
          "properties": {
            "attendanceRecordId": {
              "type": "integer"
            },
            "employmentId": {
              "type": "integer"
            },
            "workDate": {
              "type": "string",
              "format": "date"
            }
          }
        }
      }
    }
  }
}
