{
  "name": "pr-review-server",
  "version": "1.0.0",
  "description": "Local PR review server with GitHub integration and Greeting platform design principle checks",
  "type": "module",
  "scripts": {
    "setup": "bash setup.sh",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "webhook:proxy": "smee -u $SMEE_URL -t http://127.0.0.1:3847/webhook"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@octokit/webhooks": "^13.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "smee-client": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
