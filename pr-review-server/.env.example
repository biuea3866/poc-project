# === 필수 ===

# GitHub Personal Access Token (pull_requests:write, contents:read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret (GitHub webhook 등록 시 사용한 secret)
# 생성: openssl rand -hex 32
WEBHOOK_SECRET_PR_REVIEW=your_webhook_secret_here

# === 선택 ===

# Server port (default: 3847)
PORT=3847

# Smee.io webhook proxy URL
# https://smee.io/new 에서 생성 후 여기에 입력
SMEE_URL=

# Atlassian (Jira/Confluence 연동 — PR 본문 링크에서 컨텍스트 가져올 때 사용)
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_BASE_URL=https://doodlin.atlassian.net

# .analysis/ 디렉토리 경로 (default: 상위 디렉토리의 .analysis/)
ANALYSIS_DIR=
