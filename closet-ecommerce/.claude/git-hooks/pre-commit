#!/usr/bin/env bash
#
# Closet 프로젝트 pre-commit 훅
# 설치: cp .claude/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# 체크 항목:
#   1. main 브랜치 직접 커밋 차단
#   2. 금지 패턴 검출 (@Query, ConsumerRecord, LocalDateTime, FQCN, DB FK/ENUM/JSON)
#   3. 민감 파일 커밋 차단
#   4. ktlint 체크 (Kotlin 파일이 있을 때)
#

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0

# ─── 1. main 브랜치 직접 커밋 차단 (인프라 파일 예외) ───
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    # .claude/ 디렉토리만 변경된 경우 허용 (하네스 인프라)
    NON_CLAUDE_FILES=$(git diff --cached --name-only | grep -v '^\.claude/' || true)
    if [ -n "$NON_CLAUDE_FILES" ]; then
        echo -e "${RED}[BLOCKED] main 브랜치에 직접 커밋할 수 없습니다.${NC}"
        echo "  → feature 브랜치를 만들고 PR로 반영하세요."
        exit 1
    fi
    echo -e "${YELLOW}[INFO] .claude/ 인프라 파일만 변경 — main 커밋 허용${NC}"
fi

# ─── 2. 스테이지된 파일에서 금지 패턴 검출 ───
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Kotlin 금지 패턴
KT_FILES=$(echo "$STAGED_FILES" | grep '\.kt$' || true)
if [ -n "$KT_FILES" ]; then
    while IFS= read -r file; do
        # migration 파일 제외
        if echo "$file" | grep -q '/migration/'; then
            continue
        fi

        DIFF=$(git diff --cached "$file" | grep '^+' | grep -v '^+++' || true)

        # @Query 검출
        if echo "$DIFF" | grep -qE '@Query\('; then
            echo -e "${RED}[ERROR] $file: @Query 사용 금지 — QueryDSL로 작성하세요.${NC}"
            ERRORS=$((ERRORS + 1))
        fi

        # ConsumerRecord<String, String> 검출
        if echo "$DIFF" | grep -qE 'ConsumerRecord<String,\s*String>'; then
            echo -e "${RED}[ERROR] $file: ConsumerRecord<String, String> 사용 금지 — DTO 매핑 사용.${NC}"
            ERRORS=$((ERRORS + 1))
        fi

        # LocalDateTime 검출
        if echo "$DIFF" | grep -qE 'LocalDateTime'; then
            echo -e "${RED}[ERROR] $file: LocalDateTime 사용 금지 — ZonedDateTime 사용.${NC}"
            ERRORS=$((ERRORS + 1))
        fi

        # FQCN 검출
        if echo "$DIFF" | grep -qE 'com\.closet\.[a-z]+\.[a-z]+\.[A-Z]\w+\('; then
            echo -e "${YELLOW}[WARN] $file: FQCN 사용 감지 — import 문을 사용하세요.${NC}"
        fi
    done <<< "$KT_FILES"
fi

# SQL 금지 패턴
SQL_FILES=$(echo "$STAGED_FILES" | grep '\.sql$' || true)
if [ -n "$SQL_FILES" ]; then
    while IFS= read -r file; do
        DIFF=$(git diff --cached "$file" | grep '^+' | grep -v '^+++' || true)

        if echo "$DIFF" | grep -qiE 'FOREIGN KEY|REFERENCES\s+\w+\s*\('; then
            echo -e "${RED}[ERROR] $file: FK 사용 금지.${NC}"
            ERRORS=$((ERRORS + 1))
        fi

        if echo "$DIFF" | grep -qiE '\bENUM\s*\('; then
            echo -e "${RED}[ERROR] $file: DB ENUM 사용 금지.${NC}"
            ERRORS=$((ERRORS + 1))
        fi

        if echo "$DIFF" | grep -qiE '\bJSON\b'; then
            echo -e "${RED}[ERROR] $file: DB JSON 컬럼 사용 금지.${NC}"
            ERRORS=$((ERRORS + 1))
        fi
    done <<< "$SQL_FILES"
fi

# ─── 3. 민감 파일 커밋 차단 ───
SENSITIVE=$(echo "$STAGED_FILES" | grep -iE '\.(env|credentials|secret|key|pem)$|credentials\.json|secrets\.ya?ml' || true)
if [ -n "$SENSITIVE" ]; then
    echo -e "${RED}[BLOCKED] 민감 파일이 스테이지되어 있습니다:${NC}"
    echo "$SENSITIVE" | while read -r f; do echo "  • $f"; done
    echo "  → git reset HEAD <file> 로 스테이지에서 제거하세요."
    exit 1
fi

# ─── 4. ktlint 체크 (스테이지된 파일이 속한 모듈만) ───
if [ -n "$KT_FILES" ] && [ -f "closet-ecommerce/gradlew" ]; then
    # 스테이지된 kt 파일에서 변경된 모듈 추출
    CHANGED_MODULES=$(echo "$KT_FILES" | grep "closet-ecommerce/" | sed 's|closet-ecommerce/\([^/]*\)/.*|\1|' | sort -u)
    if [ -n "$CHANGED_MODULES" ]; then
        echo -e "${YELLOW}[ktlint] 변경된 모듈 린트 체크 중...${NC}"
        cd closet-ecommerce
        KTLINT_TASKS=""
        for mod in $CHANGED_MODULES; do
            if [ -d "$mod" ] && grep -q "$mod" settings.gradle.kts 2>/dev/null; then
                KTLINT_TASKS="$KTLINT_TASKS :${mod}:ktlintCheck"
            fi
        done
        if [ -n "$KTLINT_TASKS" ]; then
            if ! JAVA_HOME=/Users/biuea/Library/Java/JavaVirtualMachines/corretto-17.0.18/Contents/Home \
                 ./gradlew $KTLINT_TASKS --daemon -q 2>/dev/null; then
                echo -e "${RED}[ERROR] ktlint 체크 실패 — ./gradlew ktlintFormat 으로 자동 수정하세요.${NC}"
                ERRORS=$((ERRORS + 1))
            fi
        fi
        cd ..
    fi
fi

# ─── 결과 ───
if [ $ERRORS -gt 0 ]; then
    echo ""
    echo -e "${RED}pre-commit: ${ERRORS}개 규칙 위반 감지. 커밋이 차단됩니다.${NC}"
    exit 1
fi

echo -e "${GREEN}pre-commit: 모든 체크 통과.${NC}"
exit 0
