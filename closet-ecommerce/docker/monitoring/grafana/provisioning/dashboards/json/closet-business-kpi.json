{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "--- 주문 KPI ---",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": { "mode": "markdown", "content": "## 주문 지표" }
    },
    {
      "title": "주문 건수 (시간별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_order_created_total[1h]))",
          "legendFormat": "주문 건수",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 }
        },
        "overrides": []
      },
      "description": "[Placeholder] closet_order_created_total 커스텀 메트릭 필요"
    },
    {
      "title": "주문 상태 분포 (현재)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "closet_order_status_count",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "description": "[Placeholder] closet_order_status_count 커스텀 메트릭 필요"
    },
    {
      "title": "주문 취소율",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_order_cancelled_total[24h])) / sum(increase(closet_order_created_total[24h]))",
          "legendFormat": "취소율 (24h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "description": "[Placeholder] closet_order_cancelled_total 커스텀 메트릭 필요"
    },
    {
      "title": "평균 주문 금액 (AOV)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_order_total_amount_sum[24h])) / sum(increase(closet_order_created_total[24h]))",
          "legendFormat": "AOV (24h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyKRW",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "description": "[Placeholder] closet_order_total_amount_sum 커스텀 메트릭 필요"
    },
    {
      "title": "오늘 총 주문 건수",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_order_created_total[24h]))",
          "legendFormat": "주문",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "description": "[Placeholder] closet_order_created_total 커스텀 메트릭 필요"
    },
    {
      "title": "오늘 총 매출",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_order_total_amount_sum[24h]))",
          "legendFormat": "매출",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyKRW",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "description": "[Placeholder] closet_order_total_amount_sum 커스텀 메트릭 필요"
    },
    {
      "title": "--- 검색 KPI ---",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 14 },
      "options": { "mode": "markdown", "content": "## 검색 지표" }
    },
    {
      "title": "검색 요청 수 (시간별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_search_request_total[1h]))",
          "legendFormat": "검색 횟수",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 }
        },
        "overrides": []
      },
      "description": "[Placeholder] closet_search_request_total 커스텀 메트릭 필요"
    },
    {
      "title": "검색 전환율 (검색 -> 주문)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_search_conversion_total[1h])) / sum(increase(closet_search_request_total[1h]))",
          "legendFormat": "전환율",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "green", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "description": "[Placeholder] closet_search_conversion_total / closet_search_request_total 커스텀 메트릭 필요"
    },
    {
      "title": "인기 검색어 (Top 10)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum(increase(closet_search_keyword_count[24h])) by (keyword))",
          "legendFormat": "{{keyword}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "showHeader": true },
      "description": "[Placeholder] closet_search_keyword_count 커스텀 메트릭 필요"
    },
    {
      "title": "검색 결과 없음 비율",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(closet_search_no_result_total[24h])) / sum(increase(closet_search_request_total[24h]))",
          "legendFormat": "No Result Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "description": "[Placeholder] closet_search_no_result_total 커스텀 메트릭 필요"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["closet", "business-kpi"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Closet Business KPI",
  "uid": "closet-business-kpi",
  "version": 1
}
