# ---------------------------------------------------------
# Pinpoint Agent Configuration for Closet Ecommerce
# Version: 2.5.1
# ---------------------------------------------------------

# Transport module (gRPC)
profiler.transport.module=GRPC

# Collector connection (gRPC)
profiler.transport.grpc.collector.ip=pinpoint-collector
profiler.transport.grpc.agent.collector.port=9991
profiler.transport.grpc.metadata.collector.port=9991
profiler.transport.grpc.stat.collector.port=9992
profiler.transport.grpc.span.collector.port=9993

# Sampling rate (1 = 100%, 10 = 10%, 100 = 1%)
profiler.sampling.type=COUNTING
profiler.sampling.counting.sampling-rate=1

# Profiler settings
profiler.include=
profiler.entrypoint=

# Spring Boot plugin
profiler.springboot.enable=true
profiler.spring.beans.name.pattern=
profiler.spring.beans.class.pattern=
profiler.spring.beans.annotation=org.springframework.stereotype.Service,org.springframework.stereotype.Repository

# HTTP client plugins
profiler.apache.httpclient4.enable=true
profiler.okhttp.enable=true
profiler.resttemplate.enable=true

# JPA/Hibernate
profiler.orm.jpa.enable=true

# JDBC
profiler.jdbc.sqlcachesize=1024
profiler.jdbc.maxsqlbindvaluesize=1024
profiler.jdbc.tracesqlbindvalue=true

# Redis
profiler.redis.lettuce.enable=true
profiler.redis.redisson.enable=true

# Kafka
profiler.kafka.enable=true
profiler.kafka.producer.enable=true
profiler.kafka.consumer.enable=true

# Elasticsearch
profiler.elasticsearch.enable=true

# gRPC
profiler.grpc.enable=true

# Log
profiler.log4j2.logging.transactioninfo=true
profiler.logback.logging.transactioninfo=true

# Application type detection order
profiler.applicationservertype=SPRING_BOOT
