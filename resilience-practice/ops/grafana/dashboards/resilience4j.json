{
  "title": "Resilience4j — Order Service",
  "uid": "resilience4j-order",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["resilience4j"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CircuitBreaker State (1=현재 상태)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "max by (name, state) (resilience4j_circuitbreaker_state) == 1",
          "legendFormat": "{{name}} = {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "ON", "color": "green" } } }],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CircuitBreaker Failure Rate (%)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_failure_rate",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CircuitBreaker Calls (rate /s)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name, kind) (rate(resilience4j_circuitbreaker_calls_seconds_count[1m]))",
          "legendFormat": "{{name}} - {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "RateLimiter Available Permissions",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "resilience4j_ratelimiter_available_permissions",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Bulkhead Available Slots",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "resilience4j_bulkhead_available_concurrent_calls",
          "legendFormat": "{{name}} (avail)",
          "refId": "A"
        },
        {
          "expr": "resilience4j_bulkhead_max_allowed_concurrent_calls",
          "legendFormat": "{{name}} (max)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "TimeLimiter Calls (rate /s) by kind",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name, kind) (rate(resilience4j_timelimiter_calls_seconds_count[1m]))",
          "legendFormat": "{{name}} - {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Server Requests (rate /s) by uri & status",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{job=\"order-service\"}[1m]))",
          "legendFormat": "{{uri}} - {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
